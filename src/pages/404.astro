---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 — YARONG" description="페이지를 찾을 수 없습니다.">
  <div class="not-found shell reveal"><p class="eyebrow">Error / 404</p><h1>NOTHING<br />REMAINS HERE.</h1><p>요청한 페이지가 존재하지 않거나 이동되었습니다.</p><a class="arrow-link" href="/">Return home</a></div>
</BaseLayout>
<style>
  .not-found { min-height: 90svh; display: flex; flex-direction: column; justify-content: center; }
  h1 { margin: 2rem 0; font: 500 clamp(3.5rem, 11vw, 10rem)/.85 var(--sans); letter-spacing: -.07em; } .not-found > p:not(.eyebrow) { color: var(--muted); }
</style>
